# Copy this file's contents into Vercel's Environment Variables screen.
# Never commit a real .env.local file to GitHub.

# From Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# From account.upstox.com/developer/apps
NEXT_PUBLIC_UPSTOX_CLIENT_ID=your-upstox-api-key
UPSTOX_API_SECRET=your-upstox-api-secret
# Must exactly match the Redirect URI registered on Upstox, including https://
NEXT_PUBLIC_UPSTOX_REDIRECT_URI=https://your-app.vercel.app/api/upstox/callback

# From platform.openai.com (API Keys)
OPENAI_API_KEY=your-openai-api-key

# A random string you make up yourself (e.g. from a password generator).
# This protects the paper-trading engine endpoint from being called by anyone else.
PAPER_ENGINE_SECRET=make-up-a-long-random-string-here

# From resend.com (Get API Keys) - powers email alerts when a paper trade triggers
RESEND_API_KEY=your-resend-api-key
# Optional: only set this once you've verified your own domain on Resend
# RESEND_FROM=TradeLedger <alerts@yourdomain.com>

# A random string you make up yourself - protects the daily tax-harvest cron endpoint.
# Vercel automatically sends this as a Bearer token when it triggers scheduled crons.
CRON_SECRET=make-up-another-long-random-string

# From QuotaGuard dashboard, after signup - the proxy URL for routing
# production Delta trading calls through a static, whitelistable IP.
# Format: http://user:pass@proxy-host:port
QUOTAGUARD_URL=

# Required only if you connect Delta Exchange for real live trading.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-string

# Your own app's URL, used to build redirect links after login
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
